# ── On-chain data ──────────────────────────────────────────────────────────────
# Solana Tracker = primary trades/holders (Developer plan, data.solanatracker.io)
SOLANA_TRACKER_API_KEY=your_solana_tracker_key_here
# Free Solana RPC (Alchemy/Ankr) — used ONLY for funding-source tracing
RPC_URL=https://your-free-rpc-endpoint
# Deprecated — Helius free tier exhausted; no longer used
HELIUS_API_KEY=

# ── Enrichment APIs ────────────────────────────────────────────────────────────
GMGN_API_KEY=your_gmgn_api_key_here
BAGS_API_KEY=your_bags_api_key_here

# ── Social (optional — stub is used when absent) ───────────────────────────────
X_API_KEY=your_x_bearer_token_here

# ── LLM ────────────────────────────────────────────────────────────────────────
# Provider: "ollama" (local, default) or "anthropic" (cloud fallback)
LLM_PROVIDER=ollama
LLM_MODEL=llama3.1:8b

# Only required when LLM_PROVIDER=anthropic
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# ── Storage ────────────────────────────────────────────────────────────────────
DB_PATH=./db/copilot.db

# ── Server ─────────────────────────────────────────────────────────────────────
SERVER_HOST=0.0.0.0
SERVER_PORT=8000
